{
  "name": "witch-project",
  "private": true,
  "version": "0.0.0",
  "main": "main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "app:dev": "electron .",
    "app:build": "vite build && electron-builder",
    "app:build:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.rembyte.witchinghour",
    "productName": "The Witching Hour",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/appIcon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/appIcon.png"
    },
    "files": [
      "dist/**/*",
      "main.cjs"
    ]
  }
}
